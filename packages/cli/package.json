{
  "name": "@earnforge/cli",
  "version": "0.1.4",
  "type": "module",
  "license": "Apache-2.0",
  "description": "CLI for the LI.FI Earn API — vault discovery, risk scoring, deposit quoting, and the 18-pitfall doctor",
  "bin": {
    "earnforge": "./dist/esm/bin.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/esm/index.mjs",
      "types": "./dist/esm/index.d.mts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown src/bin.ts src/index.ts --format esm --dts --out-dir dist/esm",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@earnforge/sdk": "workspace:*",
    "commander": "^14.0.0",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
