{
  "name": "@earnforge/react",
  "version": "0.1.3",
  "type": "module",
  "license": "Apache-2.0",
  "description": "React hooks for the LI.FI Earn API — vault discovery, risk scoring, yield strategies, and deposits",
  "exports": {
    ".": {
      "import": "./dist/esm/index.mjs",
      "types": "./dist/esm/index.d.mts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --out-dir dist/esm",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@earnforge/sdk": "workspace:*"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.90.0",
    "react": ">=18",
    "viem": "^2.47.11",
    "wagmi": ">=2.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.90.0",
    "@testing-library/react": "^16.3.0",
    "jsdom": "^26.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
