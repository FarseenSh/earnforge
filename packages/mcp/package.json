{
  "name": "@earnforge/mcp",
  "version": "0.1.2",
  "type": "module",
  "license": "Apache-2.0",
  "description": "Earn-native MCP server for the LI.FI Earn API — 9 tools for vault discovery, risk scoring, and deposit quoting",
  "exports": {
    ".": {
      "import": "./dist/esm/index.mjs",
      "types": "./dist/esm/index.d.mts"
    }
  },
  "bin": {
    "earnforge-mcp": "./dist/esm/index.mjs"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --out-dir dist/esm",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@earnforge/sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
